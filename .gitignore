# =============================================================================
# SECURITY — Keys, Certs, Secrets
# =============================================================================
**/*.pem
**/*.key
**/*.crt
**/*.env
*.env
*.env.*
**/*.csv

# =============================================================================
# OS FILES
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# =============================================================================
# NODE / JAVASCRIPT / TYPESCRIPT
# =============================================================================
**/node_modules/
**/dist/
**/out/
**/.next/
**/.nuxt/
**/.vite/
**/.parcel-cache/
**/.turbo/
**/.svelte-kit/
**/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# PYTHON
# =============================================================================
**/venv/
**/.venv/
**/env/
**/.env/
*.pyc
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# =============================================================================
# JAVA / SPRING BOOT / MAVEN / GRADLE
# =============================================================================
**/target/
**/build/
**/.gradle/
**/.mvn/
*.class
**/pom.xml.tag
**/pom.xml.releaseBackup
**/pom.xml.versionsBackup
**/pom.xml.next
**/gradle/
**/gradlew.bat
**/gradlew

# =============================================================================
# TERRAFORM
# =============================================================================
# Terraform sensitive files — never commit these
terraform.tfvars
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log

# GitHub Actions key — NEVER commit this
github-actions-key.json
*.json

# =============================================================================
# DOCKER
# =============================================================================
**/.docker/
**/.dockerignore~

# =============================================================================
# KUBERNETES
# =============================================================================
**/kustomize-build/
**/.kube/

# =============================================================================
# LOGS
# =============================================================================
**/*.log
**/log/
**/logs/

# =============================================================================
# TEST & COVERAGE
# =============================================================================
**/coverage/
**/.nyc_output/
**/junit-report.xml
**/surefire-reports/

# =============================================================================
# IDE — VSCode
# =============================================================================
**/.vscode/
!**/.vscode/settings.json

# =============================================================================
# IDE — JetBrains (IntelliJ / WebStorm / PyCharm)
# =============================================================================
**/.idea/
**/*.iml
**/*.iws
**/*.ipr

# =============================================================================
# IDE — Eclipse
# =============================================================================
**/.project
**/.classpath
**/.settings/

# =============================================================================
# COMPILED BINARIES
# =============================================================================
*.o
*.so
*.dll
*.exe